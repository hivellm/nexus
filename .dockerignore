# Git
.git
.gitignore
.gitattributes

# Rust
target/
**/*.rs.bk
# Note: `Cargo.lock` is intentionally NOT ignored — the Dockerfile does
# `COPY Cargo.toml Cargo.lock ./` before the workspace build, and excluding
# it makes `docker build` fail with
# "failed to compute cache key ... /Cargo.lock not found".

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Documentation
docs/
*.md
!README.md

# Tests
tests/
**/*_test.rs
**/*_tests.rs

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Secrets
secrets/
*.pem
*.key
*.crt

# Temporary files
tmp/
temp/
*.log
*.tmp

# OS
.DS_Store
Thumbs.db

# OpenSpec
openspec/

